# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=3010
APP_NAME=MailForge

# ─── Database ────────────────────────────────────────────────────────────────
# Combined in config.go to build the MySQL DSN.
# Run `make docker-up` to start MySQL with these exact values.
DB_HOST=localhost
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
DB_NAME=mailforge

# ─── Redis ───────────────────────────────────────────────────────────────────
# Used for the job queue (asynq) and refresh token storage.
# Run `make docker-up` to start Redis.
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────
# Will be replaced with key paths in Phase B.
JWT_SECRET=supersecretkeychangethisinproduction
JWT_EXPIRY=24h

# ─── SMTP ────────────────────────────────────────────────────────────────────
# Points at MailHog for local dev — run `make docker-up` to start it.
# View caught emails at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mailforge.com

# ─── Email Provider ──────────────────────────────────────────────────────────
# Options: smtp (resend and others added in later phases)
EMAIL_PROVIDER=smtp

# ─── Workers ─────────────────────────────────────────────────────────────────
WORKER_POOL_SIZE=5

# ─── App Base URL ────────────────────────────────────────────────────────────
# Used to construct tracking links embedded in campaign emails.
DEV_APP_BASE_URL=http://localhost:3010
PROD_APP_BASE_URL=https://mailforge.tech